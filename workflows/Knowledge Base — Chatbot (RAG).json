          "name": "Gemini"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// ─── Extract Answer ───────────────────────────────────────────────\n// Pulls the generated text from the Gemini response.\n// Gemini response structure: candidates[0].content.parts[0].text\n\nconst geminiResponse = $json;\n\nconst answer = geminiResponse.candidates?.[0]?.content?.parts?.[0]?.text?.trim()\n  ?? \"I'm sorry, I couldn't generate a response. Please try again.\";\n\nconst model = geminiResponse.modelVersion ?? 'gemini-2.0-flash';\n\nreturn [\n  {\n    json: {\n      answer,\n      model,\n    },\n  },\n];\n"
      },
      "id": "8fbde2ea-db2b-4172-86d1-d0f85b93ae27",
