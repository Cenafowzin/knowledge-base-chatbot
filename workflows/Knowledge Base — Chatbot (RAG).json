{
  "name": "Knowledge Base — Chatbot (RAG)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "chat",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "9e30600b-42e9-4f2d-a09a-c8ba5a354157",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
